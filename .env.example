# Secret used to sign the session cookie AND encrypt stored service tokens at
# rest (Plex/Tautulli/Seerr). REQUIRED in production.
# Generate with:  openssl rand -hex 32
# NOTE: rotating this invalidates sessions and stored tokens (re-enter them).
SESSION_SECRET=change-me-with-openssl-rand-hex-32

# Optional: where the SQLite db lives. Defaults to ./data locally, /data in Docker.
# DATA_DIR=/data

# Optional: public URL of this app (used to build the Plex auth forwardUrl).
# If empty, the browser origin is used.
# APP_URL=https://keeparr.example.net
